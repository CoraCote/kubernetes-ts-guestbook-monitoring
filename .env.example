# Copy to `.env` in this directory (same folder as package.json).
# Values here override Pulumi stack config when you run `pulumi up` / `pulumi preview`.
# Never commit `.env` — it may contain secrets.

# Optional: absolute path to kubeconfig if not using default ~/.kube/config or KUBECONFIG
# KUBECONFIG_PATH=/home/you/.kube/config

# Minikube / local: true → Grafana NodePort, Guestbook frontend ClusterIP.
# Cloud cluster: false → Grafana LoadBalancer, Guestbook frontend LoadBalancer.
IS_MINIKUBE=true

# Grafana admin password (stored as a Pulumi secret in state). Prefer a strong value in production.
GRAFANA_ADMIN_PASSWORD=changeme

# Minikube only: fixed Service NodePort for Grafana (30000–32767). Change if it clashes on your cluster.
# GRAFANA_NODE_PORT=31302

# Helm naming (defaults avoid collisions with legacy Chart release "kps" / Grafana "guestbook-grafana")
# KUBE_PROM_HELM_RELEASE_NAME=gbmkps
# GRAFANA_HELM_FULLNAME=gbmon-grafana

# Optional: override Helm chart versions (defaults match index.ts)
# KUBE_PROM_STACK_VERSION=61.7.2
# BLACKBOX_EXPORTER_VERSION=8.17.0
# PROMETHEUS_OPERATOR_CRDS_VERSION=13.0.0   # align with kube-prometheus-stack’s prometheus-operator appVersion

# Optional: Pulumi backend (see https://www.pulumi.com/docs/cli/environment-variables/)
# PULUMI_CONFIG_PASSPHRASE=
